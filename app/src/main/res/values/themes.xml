<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme — Plantage Premium -->
    <style name="Theme.OrbitFocus" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/colorPrimaryLight</item>
        <item name="colorSecondaryVariant">@color/colorPrimary</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="android:colorBackground">@color/colorBackground</item>

        <!-- Status bar — deep forest -->
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/colorBackground</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

        <!-- Typography -->
        <item name="android:textColorPrimary">@color/colorTextPrimary</item>
        <item name="android:textColorSecondary">@color/colorTextSecondary</item>

        <!-- Material components defaults -->
        <item name="materialCardViewStyle">@style/PremiumCard</item>
        <item name="bottomNavigationStyle">@style/PremiumBottomNav</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Splash theme — full dark -->
    <style name="Theme.OrbitFocus.NoActionBar" parent="Theme.OrbitFocus">
        <item name="android:windowFullscreen">false</item>
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>

</resources>
