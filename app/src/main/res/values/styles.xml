<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ═══════ Zen Component Styles ═══════ -->

    <!-- Card -->
    <style name="ZenCard">
        <item name="android:background">@drawable/bg_card_zen</item>
        <item name="android:padding">@dimen/pad_card</item>
        <item name="android:elevation">2dp</item>
    </style>

    <!-- Primary Button (Sage Green) -->
    <style name="ZenButton">
        <item name="android:background">@drawable/bg_button_zen</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/btn_height</item>
        <item name="android:paddingStart">@dimen/btn_pad_h</item>
        <item name="android:paddingEnd">@dimen/btn_pad_h</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Danger Button (Red) -->
    <style name="ZenButtonDanger">
        <item name="android:background">@drawable/bg_button_danger</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/btn_height</item>
        <item name="android:paddingStart">@dimen/btn_pad_h</item>
        <item name="android:paddingEnd">@dimen/btn_pad_h</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Ghost / Secondary Button -->
    <style name="ZenButtonGhost">
        <item name="android:background">@drawable/bg_input_zen</item>
        <item name="android:textColor">@color/zen_text_primary</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/btn_height</item>
        <item name="android:paddingStart">@dimen/btn_pad_h</item>
        <item name="android:paddingEnd">@dimen/btn_pad_h</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- Input Field -->
    <style name="ZenInput">
        <item name="android:background">@drawable/bg_input_zen</item>
        <item name="android:textColor">@color/zen_text_primary</item>
        <item name="android:textColorHint">@color/zen_icon_inactive</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:padding">16dp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Title Text -->
    <style name="ZenTitle">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textColor">@color/zen_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Section Header -->
    <style name="ZenSection">
        <item name="android:textSize">@dimen/text_section</item>
        <item name="android:textColor">@color/zen_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Body Text -->
    <style name="ZenBody">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/zen_text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <!-- Label / Caption -->
    <style name="ZenLabel">
        <item name="android:textSize">@dimen/text_label</item>
        <item name="android:textColor">@color/zen_icon_inactive</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Settings Row -->
    <style name="ZenSettingsRow">
        <item name="android:background">@drawable/bg_card_zen</item>
        <item name="android:paddingStart">@dimen/pad_card</item>
        <item name="android:paddingEnd">@dimen/pad_card</item>
        <item name="android:paddingTop">@dimen/spacing_lg</item>
        <item name="android:paddingBottom">@dimen/spacing_lg</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <!-- Dialog -->
    <style name="ZenDialogTheme" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="android:windowBackground">@color/zen_bg</item>
        <item name="android:textColorPrimary">@color/zen_text_primary</item>
        <item name="colorAccent">@color/zen_accent</item>
        <item name="buttonBarPositiveButtonStyle">@style/ZenDialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/ZenDialogButton</item>
    </style>

    <style name="ZenDialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/zen_accent</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>
