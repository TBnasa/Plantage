<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ═══════ Plantage Premium Component Styles ═══════ -->

    <!-- Card — flat, 16dp radius -->
    <style name="PremiumCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/colorSurface</item>
        <item name="cardCornerRadius">@dimen/radius_card</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0.5dp</item>
        <item name="strokeColor">@color/colorDivider</item>
    </style>

    <style name="PremiumCard.Large">
        <item name="cardCornerRadius">@dimen/radius_card_large</item>
    </style>

    <style name="PremiumCard.Flat">
        <item name="cardBackgroundColor">@color/colorBackground</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- Bottom Nav -->
    <style name="PremiumBottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/colorBackground</item>
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemTextAppearanceActive">@style/BottomNavText</item>
        <item name="itemTextAppearanceInactive">@style/BottomNavText</item>
    </style>

    <style name="BottomNavText">
        <item name="android:textSize">11sp</item>
    </style>

    <!-- Primary Button -->
    <style name="ZenButton">
        <item name="android:background">@drawable/bg_button_zen</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/btn_height</item>
        <item name="android:paddingStart">@dimen/btn_pad_h</item>
        <item name="android:paddingEnd">@dimen/btn_pad_h</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Danger Button -->
    <style name="ZenButtonDanger">
        <item name="android:background">@drawable/bg_button_danger</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/btn_height</item>
        <item name="android:paddingStart">@dimen/btn_pad_h</item>
        <item name="android:paddingEnd">@dimen/btn_pad_h</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Ghost / Secondary Button -->
    <style name="ZenButtonGhost">
        <item name="android:background">@drawable/bg_input_zen</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/btn_height</item>
        <item name="android:paddingStart">@dimen/btn_pad_h</item>
        <item name="android:paddingEnd">@dimen/btn_pad_h</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- Input Field -->
    <style name="ZenInput">
        <item name="android:background">@drawable/bg_input_zen</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textColorHint">@color/colorTextHint</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:padding">14dp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Card background (legacy) -->
    <style name="ZenCard">
        <item name="android:background">@drawable/bg_card_zen</item>
        <item name="android:padding">@dimen/pad_card</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- Typography Styles -->
    <style name="ZenTitle">
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="ZenSection">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="ZenBody">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/colorTextSecondary</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:lineSpacingMultiplier">1.6</item>
    </style>

    <style name="ZenLabel">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/colorTextHint</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="ZenCaption">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/colorTextSecondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Settings Row -->
    <style name="ZenSettingsRow">
        <item name="android:paddingStart">@dimen/pad_card</item>
        <item name="android:paddingEnd">@dimen/pad_card</item>
        <item name="android:paddingTop">@dimen/spacing_md</item>
        <item name="android:paddingBottom">@dimen/spacing_md</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <!-- Dialog Theme -->
    <style name="ZenDialogTheme" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="android:windowBackground">@color/colorSurface</item>
        <item name="android:textColorPrimary">@color/colorTextPrimary</item>
        <item name="colorAccent">@color/colorPrimary</item>
        <item name="buttonBarPositiveButtonStyle">@style/ZenDialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/ZenDialogButton</item>
    </style>

    <style name="ZenDialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Stat Number Style -->
    <style name="StatNumber">
        <item name="android:textSize">26sp</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="StatLabel">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/colorTextSecondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

</resources>
