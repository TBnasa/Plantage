<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_card_zen"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Left: The Tree -->
        <ImageView
            android:id="@+id/widget_tree_image"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2"
            android:scaleType="fitCenter" />

        <!-- Right: Stats (Duolingo Style) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp">

            <TextView
                android:id="@+id/widget_streak_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 12"
                android:textColor="@color/colorAccent"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_total_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📖 45"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/widget_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ready to grow"
                android:textColor="@color/colorTextSecondary"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
