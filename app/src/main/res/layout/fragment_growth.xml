<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zen_bg"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/pad_screen"
        android:paddingEnd="@dimen/pad_screen"
        android:paddingTop="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_lg">

        <!-- Page title -->
        <TextView
            android:id="@+id/tvGrowthTitle"
            style="@style/ZenTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Growth 📊" />

        <TextView
            android:id="@+id/tvGrowthSubtitle"
            style="@style/ZenBody"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="Your journaling journey" />

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:orientation="horizontal">

            <!-- Streak Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:background="@drawable/bg_card_zen"
                android:elevation="2dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/pad_card_large">

                <TextView
                    android:id="@+id/tvStreakValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="0"
                    android:textColor="@color/zen_accent"
                    android:textSize="36sp" />

                <TextView
                    android:id="@+id/tvStreakLabel"
                    style="@style/ZenLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="Day Streak 🔥" />
            </LinearLayout>

            <!-- Total Memories Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:background="@drawable/bg_card_zen"
                android:elevation="2dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/pad_card_large">

                <TextView
                    android:id="@+id/tvTotalMemories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="0"
                    android:textColor="@color/zen_accent"
                    android:textSize="36sp" />

                <TextView
                    android:id="@+id/tvMemoriesLabel"
                    style="@style/ZenLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="Memories 🌿" />
            </LinearLayout>
        </LinearLayout>

        <!-- Donut Chart area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:background="@drawable/bg_card_zen"
            android:elevation="2dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/pad_card_large">

            <TextView
                android:id="@+id/tvLeafStatusLabel"
                style="@style/ZenSection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Leaf Status" />

            <com.tbnasa.plantage.MoodChartView
                android:id="@+id/moodChart"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_marginTop="@dimen/spacing_lg" />

            <!-- Legend -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Active dot -->
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@color/zen_accent" />

                <TextView
                    android:id="@+id/tvLegendActive"
                    style="@style/ZenLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:text="Active" />

                <!-- Locked dot -->
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="@dimen/spacing_lg"
                    android:background="@color/zen_accent_dark" />

                <TextView
                    android:id="@+id/tvLegendLocked"
                    style="@style/ZenLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:text="Locked" />

                <!-- Withered dot -->
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="@dimen/spacing_lg"
                    android:background="@color/zen_secondary" />

                <TextView
                    android:id="@+id/tvLegendWithered"
                    style="@style/ZenLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:text="Withered" />
            </LinearLayout>
        </LinearLayout>

        <!-- Words Written Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_card_zen"
            android:elevation="2dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/pad_card_large">

            <TextView
                android:id="@+id/tvWordsWritten"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="0"
                android:textColor="@color/zen_accent"
                android:textSize="36sp" />

            <TextView
                android:id="@+id/tvWordsLabel"
                style="@style/ZenLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="Words Written ✍️" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
