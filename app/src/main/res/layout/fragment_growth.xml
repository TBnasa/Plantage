<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/pad_screen"
        android:paddingEnd="@dimen/pad_screen"
        android:paddingTop="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_lg">

        <!-- Page title -->
        <TextView
            android:id="@+id/tvGrowthTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Seri 📊"
            android:textColor="@color/colorTextPrimary"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tvGrowthSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Your journaling journey"
            android:textColor="@color/colorTextSecondary"
            android:textSize="15sp"
            android:fontFamily="sans-serif" />

        <!-- Stat cards row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:orientation="horizontal">

            <!-- Streak Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:background="@drawable/bg_stat_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/pad_card">

                <TextView
                    android:id="@+id/tvStreakValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/colorPrimary"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvStreakLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Seri 🔥"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Total Memories Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:background="@drawable/bg_stat_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/pad_card">

                <TextView
                    android:id="@+id/tvTotalMemories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/colorPrimary"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvMemoriesLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Toplam Anı 🌿"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Leaf Status card — donut chart -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_card_zen"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/pad_card_large">

            <TextView
                android:id="@+id/tvLeafStatusLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yaprak Durumu"
                android:textColor="@color/colorTextPrimary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_gravity="start" />

            <!-- Donut chart -->
            <com.tbnasa.plantage.MoodChartView
                android:id="@+id/moodChart"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_marginTop="@dimen/spacing_lg" />

            <!-- Legend row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:background="@drawable/bg_legend_dot_active" />
                <TextView
                    android:id="@+id/tvLegendActive"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="Aktif"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="9sp" />

                <View
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:layout_marginStart="14dp"
                    android:background="@drawable/bg_legend_dot_locked" />
                <TextView
                    android:id="@+id/tvLegendLocked"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="Kilitli"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="9sp" />

                <View
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:layout_marginStart="14dp"
                    android:background="@drawable/bg_legend_dot_withered" />
                <TextView
                    android:id="@+id/tvLegendWithered"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="Solmuş"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="9sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Words Written — single line card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_stat_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/pad_card"
            android:paddingVertical="14dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="✍️"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="4"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvWordsWritten"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/colorPrimary"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvWordsLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Yazılan Kelime"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="10sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
