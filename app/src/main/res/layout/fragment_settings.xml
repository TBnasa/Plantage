<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/pad_screen"
        android:paddingEnd="@dimen/pad_screen"
        android:paddingTop="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_lg">

        <!-- Hero card: Profile -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_card"
            android:elevation="0dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Icon container -->
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_icon_container">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="🌿"
                    android:textSize="22sp" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Plantage"
                android:textColor="@color/colorTextPrimary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvSettingsSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Your mindfulness garden"
                android:textColor="@color/colorTextSecondary"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Section: PREFERENCES -->
        <TextView
            android:id="@+id/tvPrefsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:layout_marginBottom="6dp"
            android:text="PREFERENCES"
            android:textColor="@color/colorTextHint"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:textAllCaps="true" />

        <!-- Preferences card: all items in one card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_zen"
            android:orientation="vertical">

            <!-- Volume row -->
            <LinearLayout
                android:id="@+id/rowVolume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingHorizontal="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">



                    <TextView
                        android:id="@+id/tvVolumeLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Music Volume"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvVolumeValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="35%"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekVolume"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="35"
                    android:progressTint="@color/colorPrimaryLight"
                    android:thumbTint="@color/colorPrimary" />
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="@color/colorMist" android:layout_marginHorizontal="14dp" />

            <!-- Language row -->
            <LinearLayout
                android:id="@+id/rowLanguage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp">



                <TextView
                    android:id="@+id/tvLanguageLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Language"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvCurrentLang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="English"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/colorTextHint"
                    android:contentDescription="Open" />
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="@color/colorMist" android:layout_marginHorizontal="14dp" />

            <!-- Dark Mode row -->
            <LinearLayout
                android:id="@+id/rowDarkMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp">



                <TextView
                    android:id="@+id/tvDarkModeLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Dark Mode"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="15sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchDarkMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/colorPrimaryLight"
                    android:trackTint="@color/colorMist" />
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="@color/colorMist" android:layout_marginHorizontal="14dp" />

            <!-- Biometric row -->
            <LinearLayout
                android:id="@+id/rowBiometric"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp">



                <TextView
                    android:id="@+id/tvBiometricLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Biometric Lock"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="15sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchBiometric"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/colorPrimaryLight"
                    android:trackTint="@color/colorMist" />
            </LinearLayout>

            <!-- Notification Frequency row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/tvFrequencyLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Reminder Frequency"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="15sp" />
                    <TextView
                        android:id="@+id/tvFrequencyValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5h"
                        android:textColor="@color/colorPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekFrequency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:max="1380"
                    android:progress="300"
                    android:progressTint="@color/colorPrimary"
                    android:thumbTint="@color/colorPrimary" />
            </LinearLayout>

        </LinearLayout>

        <!-- Section: BACKUP & RESTORE -->
        <TextView
            android:id="@+id/tvBackupLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:layout_marginBottom="6dp"
            android:text="BACKUP &amp; RESTORE"
            android:textColor="@color/colorTextHint"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:textAllCaps="false" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_zen"
            android:orientation="vertical">

            <!-- Export row -->
            <LinearLayout
                android:id="@+id/rowExport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp">



                <TextView
                    android:id="@+id/tvExportLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Export Data (.plntg)"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="@color/colorMist" android:layout_marginHorizontal="14dp" />

            <!-- Import row -->
            <LinearLayout
                android:id="@+id/rowImport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp">



                <TextView
                    android:id="@+id/tvImportLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Import Data (.plntg)"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Section: ABOUT -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:layout_marginBottom="6dp"
            android:text="ABOUT"
            android:textColor="@color/colorTextHint"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:textAllCaps="true" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_zen"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/rowAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp">



                <TextView
                    android:id="@+id/tvAboutLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="About Plantage"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="15sp" />

                <!-- Version badge chip -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v1.0"
                    android:textColor="@color/colorSage"
                    android:textSize="11sp"
                    android:background="@drawable/bg_version_chip"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp" />
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="@color/colorMist" android:layout_marginHorizontal="14dp" />

            <!-- Github Row -->
            <LinearLayout
                android:id="@+id/rowGithub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_github"
                    android:layout_marginEnd="10dp"
                    app:tint="@color/colorTextPrimary" />

                <TextView
                    android:id="@+id/tvGithubLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Github Repository"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/colorTextHint" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
