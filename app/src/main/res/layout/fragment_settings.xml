<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zen_bg"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/pad_screen"
        android:paddingEnd="@dimen/pad_screen"
        android:paddingTop="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_lg">

        <!-- Profile Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_zen"
            android:elevation="2dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/pad_card_large">

            <!-- Profile circle -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_profile_circle" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="🌿"
                    android:textSize="32sp" />
            </FrameLayout>

            <TextView
                style="@style/ZenSection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="Plantage" />

            <TextView
                android:id="@+id/tvSettingsSubtitle"
                style="@style/ZenLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="Your mindfulness garden" />
        </LinearLayout>

        <!-- Settings List -->
        <TextView
            android:id="@+id/tvPrefsLabel"
            style="@style/ZenLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:layout_marginStart="@dimen/spacing_sm"
            android:text="PREFERENCES"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <!-- Volume Row -->
        <LinearLayout
            android:id="@+id/rowVolume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_card_zen"
            android:elevation="1dp"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/pad_card"
            android:paddingVertical="@dimen/spacing_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvVolumeLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔊 Music Volume"
                    android:textColor="@color/zen_text_primary"
                    android:textSize="@dimen/text_body" />

                <TextView
                    android:id="@+id/tvVolumeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="35%"
                    android:textColor="@color/zen_accent"
                    android:textSize="@dimen/text_body"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekVolume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:max="100"
                android:progress="35"
                android:progressTint="@color/zen_accent"
                android:thumbTint="@color/zen_accent" />
        </LinearLayout>

        <!-- Language Row -->
        <LinearLayout
            android:id="@+id/rowLanguage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_card_zen"
            android:elevation="1dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/pad_card"
            android:paddingVertical="@dimen/spacing_lg">

            <TextView
                android:id="@+id/tvLanguageLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🌐 Language"
                android:textColor="@color/zen_text_primary"
                android:textSize="@dimen/text_body" />

            <TextView
                android:id="@+id/tvCurrentLang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="English"
                android:textColor="@color/zen_accent"
                android:textSize="@dimen/text_body"
                android:fontFamily="sans-serif-medium" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="@dimen/spacing_sm"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/zen_icon_inactive"
                android:contentDescription="Open" />
        </LinearLayout>





        <!-- Dark Mode Row -->
        <LinearLayout
            android:id="@+id/rowDarkMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_card_zen"
            android:elevation="1dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/pad_card"
            android:paddingVertical="@dimen/spacing_lg">

            <TextView
                android:id="@+id/tvDarkModeLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🌙 Dark Mode"
                android:textColor="@color/zen_text_primary"
                android:textSize="@dimen/text_body" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchDarkMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/zen_accent"
                android:trackTint="@color/zen_accent_light" />
        </LinearLayout>

        <!-- Biometric Lock Row -->
        <LinearLayout
            android:id="@+id/rowBiometric"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_card_zen"
            android:elevation="1dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/pad_card"
            android:paddingVertical="@dimen/spacing_lg">

            <TextView
                android:id="@+id/tvBiometricLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔒 Biometric Lock"
                android:textColor="@color/zen_text_primary"
                android:textSize="@dimen/text_body" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchBiometric"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/zen_accent"
                android:trackTint="@color/zen_accent_light" />
        </LinearLayout>
        
        <!-- Backup & Restore Section -->
        <TextView
            android:id="@+id/tvBackupLabel"
            style="@style/ZenLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:layout_marginStart="@dimen/spacing_sm"
            android:text="BACKUP &amp; RESTORE"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <LinearLayout
            android:id="@+id/rowExport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_card_zen"
            android:elevation="1dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/pad_card"
            android:paddingVertical="@dimen/spacing_lg">

            <TextView
                android:id="@+id/tvExportLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📤 Export Data (.plntg)"
                android:textColor="@color/zen_text_primary"
                android:textSize="@dimen/text_body" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowImport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_card_zen"
            android:elevation="1dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/pad_card"
            android:paddingVertical="@dimen/spacing_lg">

            <TextView
                android:id="@+id/tvImportLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📥 Import Data (.plntg)"
                android:textColor="@color/zen_text_primary"
                android:textSize="@dimen/text_body" />
        </LinearLayout>

        <!-- About Row -->
        <LinearLayout
            android:id="@+id/rowAbout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_card_zen"
            android:elevation="1dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/pad_card"
            android:paddingVertical="@dimen/spacing_lg">

            <TextView
                android:id="@+id/tvAboutLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ℹ️ About Plantage"
                android:textColor="@color/zen_text_primary"
                android:textSize="@dimen/text_body" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0"
                android:textColor="@color/zen_icon_inactive"
                android:textSize="@dimen/text_label" />
        </LinearLayout>

        <!-- GitHub Row -->
        <LinearLayout
            android:id="@+id/rowGithub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_card_zen"
            android:elevation="1dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/pad_card"
            android:paddingVertical="@dimen/spacing_lg">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_github"
                android:tint="@color/zen_text_primary"
                android:layout_marginEnd="@dimen/spacing_md" />

            <TextView
                android:id="@+id/tvGithubLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Github"
                android:textColor="@color/zen_text_primary"
                android:textSize="@dimen/text_body" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="@color/zen_icon_inactive" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
