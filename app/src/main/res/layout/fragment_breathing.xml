<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvZenTitle"
        style="@style/ZenTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"
        android:text="@string/zen_mode_title" />

    <FrameLayout
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginBottom="48dp">

        <!-- Breathing Circle -->
        <View
            android:id="@+id/breathingCircle"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_profile_circle"
            android:backgroundTint="@color/colorPrimary"
            android:alpha="0.4" />

        <!-- Timer Counter -->
        <TextView
            android:id="@+id/tvTimerCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="sans-serif-light"
            android:textColor="@color/colorTextPrimary"
            android:textSize="64sp"
            android:text="4" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvZenInstruction"
        style="@style/ZenSection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="64dp"
        android:text="@string/inhale"
        android:textColor="@color/colorPrimary" />

    <Button
        android:id="@+id/btnZenAction"
        style="@style/ZenButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/start_zen" />

</LinearLayout>