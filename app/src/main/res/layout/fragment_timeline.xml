<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zen_bg"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/pad_screen"
        android:paddingEnd="@dimen/pad_screen"
        android:paddingTop="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_lg">

        <!-- Greeting -->
        <TextView
            android:id="@+id/tvGreeting"
            style="@style/ZenTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Good morning" />

        <TextView
            android:id="@+id/tvDate"
            style="@style/ZenBody"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="Today" />

        <!-- Countdown -->
        <LinearLayout
            android:id="@+id/layoutCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_card_zen"
            android:padding="@dimen/spacing_md">
             <TextView
                android:id="@+id/tvCountdown"
                style="@style/ZenBody"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00" />
        </LinearLayout>

        <!-- Plant Memory -->
        <LinearLayout
            android:id="@+id/cardPlantMemory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:background="@drawable/bg_card_zen"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/pad_card">
             <TextView
                android:id="@+id/tvPlantHint"
                style="@style/ZenBody"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Plant a memory..."
                android:textColor="@color/zen_text_secondary" />
             <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/zen_icon_inactive" />
        </LinearLayout>

        <!-- Tree View -->
        <com.tbnasa.plantage.PlantageTreeView
            android:id="@+id/plantageTreeView"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:layout_marginTop="@dimen/spacing_xl" />

        <!-- Section Title -->
        <TextView
            android:id="@+id/tvRecentTitle"
            style="@style/ZenSection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="Recent Memories" />

        <!-- Cards -->
        <LinearLayout
            android:id="@+id/layoutMemoryCards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:orientation="vertical" />

        <!-- Empty State -->
        <TextView
            android:id="@+id/tvEmptyState"
            style="@style/ZenBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:gravity="center"
            android:text="No memories yet"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
